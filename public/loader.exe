local Supported = {
	[74708667430033] = "https://raw.githubusercontent.com/5gm/scripts/refs/heads/main/Pet%20Crystal%20simulatorui2.lua",
        [7436755782] = "https://raw.githubusercontent.com/RecryDv/sh0velprod/refs/heads/main/garden.luau"
}

local ID = game.GameId
local gm = Supported[ID]

if gm == nil then
	warn("yoza. -> Game is not supported")
	return
end

loadstring(game:HttpGet(gm))()
