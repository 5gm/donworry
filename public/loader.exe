local HttpService = game:GetService("HttpService")

local scriptUrls = {
    [74708667430033] = "https://raw.githubusercontent.com/5gm/scripts/refs/heads/main/Pet%20Crystal%20simulatorui2.lua",
    [120119241483509] = "https://raw.githubusercontent.com/5gm/scripts/refs/heads/main/Pet%20Incremental.lua"
}

local url = scriptUrls[game.PlaceId]

if url then
    local success, scriptCode = pcall(function() return HttpService:GetAsync(url) end)
    if success then
        local func, err = loadstring(scriptCode)
        if func then
            func()
        else
            warn("Error executing script:", err)
        end
    else
        warn("Failed to fetch script:", scriptCode)
    end
else
    warn("No script found for PlaceId:", game.PlaceId)
end
